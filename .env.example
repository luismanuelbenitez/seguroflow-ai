# =============================================================================
# SeguroFlow AI - Variables de entorno
# Copiar este archivo como .env.local y completar con valores reales.
# NUNCA commitear .env.local al repositorio.
# NUNCA poner valores reales en este archivo.
# =============================================================================

# --- Supabase ---
# URL del proyecto Supabase (safe para exponer al cliente)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key de Supabase (safe para el cliente - acceso controlado por RLS)
# Ver: lib/supabase/client.ts
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Service role key de Supabase (SECRETO - NUNCA exponer al cliente)
# Solo para server-side: webhooks, cron jobs, operaciones del sistema.
# Ver: docs/04-decisiones/DECISION-003-multitenant-rls.md, Seccion 6.
SUPABASE_SERVICE_ROLE_KEY=

# --- Proveedor de IA ---
# Proveedor activo: 'anthropic' | 'openai' | 'ollama'
# Ver: lib/ai/adapters/README.md
AI_PROVIDER=

# Modelo para generacion de mensajes de seguimiento.
# Valor esperado para produccion: claude-sonnet-4-6
# Ver: docs/04-decisiones/DECISION-002-stack-tecnologico-inicial.md
AI_GENERATION_MODEL=

# Modelo para clasificacion de respuestas de prospectos.
# Valor esperado para produccion: claude-haiku-4-5-20251001
AI_CLASSIFICATION_MODEL=

# API key del proveedor de IA (SECRETO - NUNCA exponer al cliente)
AI_API_KEY=

# --- Proveedor de WhatsApp Business API (WABA) ---
# Proveedor activo: 'twilio' | '360dialog' | 'meta_direct'
# Ver: lib/whatsapp/adapters/README.md
WHATSAPP_PROVIDER=

# Secreto para verificar la firma HMAC de los webhooks entrantes (SECRETO)
# Todos los webhooks deben verificar esta firma antes de procesar datos.
# Ver: server/README.md
WHATSAPP_WEBHOOK_SECRET=

# Credenciales especificas del proveedor WABA (SECRETO)
# El nombre exacto de estas variables depende del proveedor elegido.
# Ejemplos para Twilio sandbox:
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=
